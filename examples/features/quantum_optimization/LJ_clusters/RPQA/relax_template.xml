<simulation mode="static" verbosity="medium" >
  <output prefix='min'>
	  <properties stride='5' filename='out'>  [ step,temperature{kelvin}, bead_potentials{electronvolt}  ] </properties>
    <trajectory filename='pos' stride='5'> positions </trajectory>
  </output>
   <total_steps>5000       </total_steps>
  <ffsocket mode='unix' name='lj_driver' pbc='False'>
    <address>localhost</address>
  </ffsocket>
   <system >
       <initialize nbeads='32'> 
           <file mode='chk' > RESTART </file>
       </initialize>
       <forces>
           <force forcefield='lj_driver'> </force>
       </forces>
    <motion mode='minimize'>
           <fixcom>False</fixcom>
      <optimizer mode='cg'>
        <tolerances>
          <energy> 1e-5 </energy>
          <force> 1e-3 </force>
          <position> 5e-3 </position>
        </tolerances>
      </optimizer>
    </motion>
   </system>
</simulation>
