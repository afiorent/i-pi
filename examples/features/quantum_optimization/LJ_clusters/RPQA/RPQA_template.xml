<simulation mode="static" verbosity="medium">
	<output prefix='{{fsimulation}}'>
    <properties stride='{{stride}}' filename='out'>  [ step, time{picosecond}, conserved{kelvin}, temperature{kelvin}, kinetic_cv{kelvin}, potential{electronvolt}, pressure_cv{megapascal}, kinetic_td{kelvin},lambdaqkin ] </properties>
    <trajectory filename='pos' stride='{{stride}}'> positions </trajectory>
    <trajectory filename='roc' stride='{{stride}}'> x_centroid </trajectory>
  </output>
   <total_steps>{{simu_steps}}       </total_steps>
  <ffsocket mode='unix' name='lj_driver' pbc='False'>
    <address>localhost</address>
      <latency>0.0001</latency>
  </ffsocket>
   <system >
       <initialize nbeads='{{nbeads}}'> 
	       <file mode='ase' >  {{init_file}} </file>
        	<!--very large cell to avoid interaction through PBC -->
           <cell mode='abc'> [300.0,  300.0,  300.0  ] </cell>
       </initialize>
       <forces>
           <force forcefield='lj_driver'> </force>
       </forces>
       <ensemble>
           <temperature units="kelvin">{{temperature}} </temperature>
           <lambdaqkin>{{hbar2_0}}</lambdaqkin>
       </ensemble>
    <normal_modes propagator='bab'></normal_modes>	
    <motion mode='multi'>
       <motion mode='dynamics'>
	   <fixcom>False</fixcom>
	   <fixbeads>{{fixbeads}}</fixbeads>
           <dynamics mode='nvt'>
               <thermostat mode='langevin'>
                 <tau units='femtosecond'> 10 </tau>
               </thermostat>
               <timestep units='femtosecond'> 0.5 </timestep>
           </dynamics>
       </motion>
    <motion mode="qkin_ramp">
       <qkin_ramp>
         <lambda_start> {{hbar2_0}} </lambda_start>
         <lambda_end> {{hbar2_1}} </lambda_end>
         <total_steps>{{QA_steps}}  </total_steps>
         <logscale> False </logscale>
         <sqrtscale> {{sqrt_scale}} </sqrtscale>
     </qkin_ramp>
    </motion>
    </motion>
   </system>
</simulation>
